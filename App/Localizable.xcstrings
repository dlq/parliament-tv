    "player.dash.unsupported.body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This source needs a web-based MPEG-DASH player, which is not part of the tvOS native player path."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette source nécessite un lecteur MPEG-DASH Web, qui ne fait pas partie du parcours natif tvOS."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta fonte precisa de um player MPEG-DASH baseado na Web, que não faz parte do caminho nativo do tvOS."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Denne kilde kræver en webbaseret MPEG-DASH-afspiller, som ikke er en del af den native tvOS-afspiller."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Deze bron heeft een webgebaseerde MPEG-DASH-speler nodig, die geen deel uitmaakt van het native tvOS-spelerpad."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta fuente necesita un reproductor MPEG-DASH basado en la web, que no forma parte de la ruta del reproductor nativo de tvOS."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Αυτή η πηγή χρειάζεται διαδικτυακό πρόγραμμα αναπαραγωγής MPEG-DASH, το οποίο δεν αποτελεί μέρος της εγγενούς διαδρομής αναπαραγωγής tvOS."
          }
        },
        "lb": {
          "stringUnit": {
            "state": "translated",
            "value": "Dës Quell brauch en webbaséierte MPEG-DASH Player, deen net Deel vum native tvOS Player-Wee ass."
          }
        },
        "it": {
          "stringUnit": {
